# API Authentication
API_KEY=your-api-key

# Redis Configuration (required for Celery async processing)
REDIS_URL=redis://localhost:6379/0

# Set to "sync" to bypass Celery/Redis (for local development)
# Set to "async" to use Celery workers (production)
PROCESSING_MODE=sync

# Tesseract OCR path (Windows — update to your install path)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
